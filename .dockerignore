# Keep the Docker build context small — only ship the backend.
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env
.env.*

# Vercel-only files
.vercel/

# Frontend — Render doesn't need it
frontend/

# Sample binaries / demo GIFs
samples/
docs/
*.gif
*.mp4

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Git
.git/
.gitignore
